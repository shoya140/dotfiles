{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git rev-parse *)",
      "Bash(git symbolic-ref *)",
      "Bash(git remote -v)",
      "Bash(git fetch --prune *)",
      "Bash(git pull --ff-only *)",
      "Bash(npm run lint*)",
      "Bash(npm test*)",
      "Bash(* --version)",
      "Bash(* --help *)"
    ],
    "deny": [
      "Bash(git push *)",
      "Bash(git push)",
      "Bash(git commit --amend*)",
      "Bash(git reset --hard*)",
      "Bash(git reset --mixed*)",
      "Bash(git reset --soft*)",
      "Bash(git clean -f*)",
      "Bash(git clean -d*)",
      "Bash(git rebase *)",
      "Bash(git checkout -- *)",
      "Bash(git restore -- *)",
      "Bash(git config --global *)",
      "Bash(git config -g *)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(./secrets/**)",
      "Read(./config/credentials.*)",
      "Edit(./.env*)",
      "Write(./.env*)"
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true
  },
  "skipDangerousModePermissionPrompt": true,
  "effortLevel": "high",
  "hooks": {
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/worktree-create.sh"
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/worktree-remove.sh"
          }
        ]
      }
    ]
  }
}
